SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=sqlite:///./campus_lostfound.db
UPLOAD_DIR=backend/uploads
CLIP_THRESHOLD=0.70

# ── Email notifications ────────────────────────────────────────────────────────
# Uses Brevo free SMTP — sign up at brevo.com, no 2FA required, 300 emails/day free.
# Leave SMTP_HOST blank to disable notifications (app works fine without them).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-signup-email@gmail.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_FROM=noreply@lumslostfound.com
